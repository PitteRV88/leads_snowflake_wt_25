# =============================================================
# secrets.toml.example - PLANTILLA de secretos para Streamlit Community Cloud
# Autenticacion: Key-Pair (RSA) - mas seguro que password
# NUNCA subir el archivo secrets.toml real a GitHub
# Copiar como secrets.toml y llenar con valores reales
# O configurar directamente en Streamlit Community Cloud > App Settings > Secrets
# =============================================================

[snowflake]
account = "TU_ACCOUNT_ID"
user = "TU_USUARIO"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...(contenido completo de rsa_key.p8 con \\n en lugar de saltos de linea)...\n-----END PRIVATE KEY-----"
warehouse = "COMPUTE_WH"
database = "DB_LEADS_SNOWFLAKE_WT25"
role = "LEADS_DASHBOARD_ROLE"
